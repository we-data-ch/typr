
# Column i (module boundary) x row 1 (S3 external, `lm`) of interop_matrix.md.
# soundness_plan.md D.2: a @pub fn whose dispatch param is Foreign<T> must be
# reachable from OUTSIDE the module that declares it.
type LmModel <- Foreign<Any>;
@extern base::readRDS: (path: char) -> LmModel;

module Reporter {
    @pub let describe <- fn(x: LmModel): int { print(x); 1 };
};

use Reporter::describe;

let m <- readRDS("fixtures/lm.rds");
print(describe(m));
