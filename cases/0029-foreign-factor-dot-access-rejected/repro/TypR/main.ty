
# Row 7 (base vector with attributes) x column f (dot/dollar access) of
# interop_matrix.md. Deliberate hole, not a bug: Foreign<T> reduces to Any,
# which has no structural fields, so `f.levels` can never type-check.
# Reaching a foreign value's attributes requires an explicit @extern
# accessor (e.g. `base::levels`) instead.
type FactorExt <- Foreign<Any>;
@extern base::readRDS: (path: char) -> FactorExt;

let f <- readRDS("fixtures/factor_ext.rds");
print(f.raw_levels);
