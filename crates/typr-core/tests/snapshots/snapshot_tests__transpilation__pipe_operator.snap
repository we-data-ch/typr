source: crates/typr-core/tests/snapshot_tests.rs
assertion_line: 144
expression: r
---
Point <- function(x, y, .spread = NULL) {
  explicit <- list()
  if (!missing(x)) explicit[["x"]] <- x
  if (!missing(y)) explicit[["y"]] <- y
  x <- typr_spread_record(explicit, .spread)
  as.Point(x)
}
as.Point <- function(x) {
  if (!inherits(x, "Point")) class(x) <- c("Point", "list")
  x <- validate_Point(x)
  x <- validate(x)
  x
}
validate_Point <- function(x) {
  required_fields <- c("x", "y")
  missing_fields <- setdiff(required_fields, names(x))
  if (length(missing_fields) > 0) {
    stop(paste0("Validation failed for type Point: missing fields: ", paste(missing_fields, collapse = ", ")))
  }
  if (!inherits(x[["x"]], "integer")) stop("Validation failed for type Point: field 'x' must be of class integer")
  if (!inherits(x[["y"]], "integer")) stop("Validation failed for type Point: field 'y' must be of class integer")
  x
}
`incr.Point` <- (function(p) {
Point(x = {
p$x + 1L |> as.Integer()
}, y = {
p$y + 1L |> as.Integer()
})
}) |> as.Generic()

incr(Point(x = 5L |> as.Integer(), y = 12L |> as.Integer()))
