Binaire <- function(x) {
  validate_Binaire(x)
}
validate_Binaire <- function(x) {
  if (!inherits(x, "logical")) stop("Validation failed for type Binaire: expected vector of logical")
  x
}
Binaire(c(TRUE |> as.Boolean(), TRUE |> as.Boolean(), FALSE |> as.Boolean(), TRUE |> as.Boolean()))
