`both.integer` <- (function(a, b) {
if(a > b) {
a 
} else b
} |> as.Integer()) |> as.Function0()

`v` <- c(1L |> as.Integer(), 2L |> as.Integer(), 3L |> as.Integer()) |> identity()

`w` <- c(4L |> as.Integer(), 5L |> as.Integer(), 6L |> as.Integer()) |> identity()

`r` <- vapply(seq_along(v), function(.typr_i) both(v[[.typr_i]], w[[.typr_i]]), integer(1), USE.NAMES = FALSE)
